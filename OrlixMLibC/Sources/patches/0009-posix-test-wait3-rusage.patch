diff --git i/tests/posix/wait3.c w/tests/posix/wait3.c
new file mode 100644
index 00000000..5fb4091d
--- /dev/null
+++ w/tests/posix/wait3.c
@@ -0,0 +1,46 @@
+#include <assert.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/resource.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+static int rusage_was_written(const struct rusage *ru) {
+	unsigned char sentinel[sizeof(*ru)];
+	memset(sentinel, 0x5a, sizeof(sentinel));
+	return memcmp(ru, sentinel, sizeof(*ru)) != 0;
+}
+
+int main() {
+	pid_t pid = fork();
+	assert(pid >= 0);
+
+	if(!pid) {
+		volatile unsigned long value = 0;
+		for(unsigned long i = 0; i < 100000; i++)
+			value += i;
+		(void)value;
+		_exit(23);
+	}
+
+	int status = 0;
+	struct rusage ru;
+	memset(&ru, 0x5a, sizeof(ru));
+
+	pid_t waited = wait3(&status, 0, &ru);
+	assert(waited == pid);
+	assert(WIFEXITED(status));
+	assert(WEXITSTATUS(status) == 23);
+	assert(rusage_was_written(&ru));
+
+	pid = fork();
+	assert(pid >= 0);
+	if(!pid)
+		_exit(0);
+
+	memset(&ru, 0x5a, sizeof(ru));
+	waited = wait4(pid, &status, 0, &ru);
+	assert(waited == pid);
+	assert(rusage_was_written(&ru));
+	return 0;
+}
