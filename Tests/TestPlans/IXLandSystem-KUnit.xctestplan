{
  "configurations": [
    {
      "id": "KUnit-Tests",
      "name": "KUnit White-Box Tests",
      "options": {
        "testRepetitionMode": "none"
      }
    }
  ],
  "defaultOptions": {
    "testRepetitionMode": "none",
    "testTimeoutsEnabled": true,
    "testTimeout": 30
  },
  "testTargets": [
    {
      "target": {
        "containerPath": "container:IXLand.xcodeproj",
        "identifier": "IXLandSystemKUnitTests",
        "name": "IXLandSystemKUnitTests"
      }
    }
  ],
  "version": 1
}
