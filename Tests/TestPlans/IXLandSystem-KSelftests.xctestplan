{
  "configurations": [
    {
      "id": "KSelftests",
      "name": "KSelftests Black-Box Tests",
      "options": {
        "testRepetitionMode": "none"
      }
    }
  ],
  "defaultOptions": {
    "testRepetitionMode": "none",
    "testTimeoutsEnabled": true,
    "testTimeout": 60
  },
  "testTargets": [
    {
      "target": {
        "containerPath": "container:IXLand.xcodeproj",
        "identifier": "IXLandSystemKSelftests",
        "name": "IXLandSystemKSelftests"
      }
    }
  ],
  "version": 1
}
