# clangd configuration for IXLandSystem
# This file uses portable relative paths - no machine-specific hardcoding
#
# IMPORTANT: This config works WITH compile_commands.json, not instead of it.
# - compile_commands.json provides real per-file build context (include paths, language mode, target, macros)
# - This .clangd file provides portable fallback flags and path-based policy
# - clangd uses compile_commands.json when available, falls back to these flags
#
# To generate compile_commands.json locally:
#   ./scripts/generate_compile_commands.sh
# This is intentionally NOT checked in - it's machine-specific.

# By default, clangd searches upward from the file being edited for compile_commands.json
# This is the recommended behavior - it finds the CDB at repo root when available

---
# Linux-owner paths: C-only, no Objective-C
# These paths implement Linux semantics and must stay host-agnostic
If:
  PathMatch:
    - ^fs/.*\.(c|h)$
    - ^kernel/.*\.(c|h)$
    - ^runtime/.*\.(c|h)$
    - ^include/.*\.h$
    - ^arch/darwin/.*\.(c|h)$
  PathExclude:
    - ^internal/ios/.*$
    - ^IXLandSystemTests/.*$
  CompileFlags:
    Add:
      - -DIXLAND_LINUX_OWNER_FILE=1
      - --include=include/ixland/clangd_owner_policy.h
      - -std=gnu11
      # Portable fallback includes - compile_commands.json provides the real paths
      - -Ithird_party/linux-uapi/6.12/arm64/include
      - -Iinclude
      - -I.
      - -D_XOPEN_SOURCE
    Remove:
      - -index-store-path
      - -index-unit-output-path

---
# Private iOS bridge paths
# Host-specific mediation quarantined under internal/ios
If:
  PathMatch:
    - ^internal/ios/.*\.(c|h|m|mm)$
  CompileFlags:
    Add:
      - -DIXLAND_HOST_BRIDGE_FILE=1
      - -std=gnu11

---
# Private iOS: Objective-C files
If:
  PathMatch:
    - ^internal/ios/.*\.m$
  CompileFlags:
    Add:
      - -x
      - objective-c
      - -fobjc-arc

---
# Private iOS: Objective-C++ files
If:
  PathMatch:
    - ^internal/ios/.*\.mm$
  CompileFlags:
    Add:
      - -x
      - objective-c++
      - -fobjc-arc

---
# Tests: Objective-C
If:
  PathMatch:
    - ^IXLandSystemTests/.*\.m$
  CompileFlags:
    Add:
      - -x
      - objective-c
      - -fobjc-arc
      - -fmodules

---
# Tests: Objective-C++
If:
  PathMatch:
    - ^IXLandSystemTests/.*\.mm$
  CompileFlags:
    Add:
      - -x
      - objective-c++
      - -fobjc-arc
      - -fmodules

---
# Tests: C with strict diagnostics
If:
  PathMatch:
    - ^IXLandSystemTests/.*\.(c|h)$
  Diagnostics:
    ClangTidy:
      FastCheckFilter: Strict
