CompileFlags:
  CompilationDatabase: .
  Remove:
    - -index-store-path
    - -index-unit-output-path

---
# Linux-owner paths: C-only, no ObjC
If:
  PathMatch:
    - ^fs/.*\.(c|h)$
    - ^kernel/.*\.(c|h)$
    - ^runtime/.*\.(c|h)$
    - ^include/.*\.h$
    - ^arch/darwin/.*\.(c|h)$
  PathExclude:
    - ^internal/ios/.*$
    - ^IXLandSystemTests/.*$
  CompileFlags:
    Add:
      - -DIXLAND_LINUX_OWNER_FILE=1
      - --include=include/ixland/clangd_owner_policy.h

---
# Private iOS bridge paths
If:
  PathMatch:
    - ^internal/ios/.*\.(c|h|m|mm)$
  CompileFlags:
    Add:
      - -DIXLAND_HOST_BRIDGE_FILE=1

---
# Private iOS: Objective-C files
If:
  PathMatch:
    - ^internal/ios/.*\.m$
  CompileFlags:
    Add:
      - -x
      - objective-c

---
# Private iOS: Objective-C++ files
If:
  PathMatch:
    - ^internal/ios/.*\.mm$
  CompileFlags:
    Add:
      - -x
      - objective-c++

---
# Tests: Objective-C
If:
  PathMatch:
    - ^IXLandSystemTests/.*\.m$
  CompileFlags:
    Add:
      - -x
      - objective-c

---
# Tests: Objective-C++
If:
  PathMatch:
    - ^IXLandSystemTests/.*\.mm$
  CompileFlags:
    Add:
      - -x
      - objective-c++

---
# Tests: C with strict diagnostics
If:
  PathMatch:
    - ^IXLandSystemTests/.*\.(c|h)$
  Diagnostics:
    ClangTidy:
      FastCheckFilter: Strict
