# clangd configuration for IXLandSystem
# This file uses portable relative paths - no machine-specific hardcoding

CompileFlags:
  # Base flags applied to all files
  Add:
    - -Ithird_party/linux-uapi/6.12/arm64/include
    - -Iinclude
    - -I.
    - -D_XOPEN_SOURCE
  Remove:
    - -index-store-path
    - -index-unit-output-path

---
# Linux-owner paths: C-only, no ObjC
# These paths implement Linux semantics and must stay host-agnostic
If:
  PathMatch:
    - ^fs/.*\.(c|h)$
    - ^kernel/.*\.(c|h)$
    - ^runtime/.*\.(c|h)$
    - ^include/.*\.h$
    - ^arch/darwin/.*\.(c|h)$
  PathExclude:
    - ^internal/ios/.*$
    - ^IXLandSystemTests/.*$
  CompileFlags:
    Add:
      - -DIXLAND_LINUX_OWNER_FILE=1
      - --include=include/ixland/clangd_owner_policy.h
      - -std=gnu11

---
# Private iOS bridge paths
# Host-specific mediation quarantined under internal/ios
If:
  PathMatch:
    - ^internal/ios/.*\.(c|h|m|mm)$
  CompileFlags:
    Add:
      - -DIXLAND_HOST_BRIDGE_FILE=1
      - -std=gnu11

---
# Private iOS: Objective-C files
If:
  PathMatch:
    - ^internal/ios/.*\.m$
  CompileFlags:
    Add:
      - -x
      - objective-c
      - -fobjc-arc

---
# Private iOS: Objective-C++ files  
If:
  PathMatch:
    - ^internal/ios/.*\.mm$
  CompileFlags:
    Add:
      - -x
      - objective-c++
      - -fobjc-arc

---
# Tests: Objective-C
If:
  PathMatch:
    - ^IXLandSystemTests/.*\.m$
  CompileFlags:
    Add:
      - -x
      - objective-c
      - -fobjc-arc
      - -fmodules

---
# Tests: Objective-C++
If:
  PathMatch:
    - ^IXLandSystemTests/.*\.mm$
  CompileFlags:
    Add:
      - -x
      - objective-c++
      - -fobjc-arc
      - -fmodules

---
# Tests: C with strict diagnostics
If:
  PathMatch:
    - ^IXLandSystemTests/.*\.(c|h)$
  Diagnostics:
    ClangTidy:
      FastCheckFilter: Strict
